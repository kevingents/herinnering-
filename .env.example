# ─────────────────────────────────────────────────────────────────────────
# Levend Graf — environment
# Copy to `.env.local` and fill in. Public site runs without these; the app,
# database and AI features activate as soon as the relevant values are set.
# ─────────────────────────────────────────────────────────────────────────

# ── Supabase (Project Settings → API) ──────────────────────────────────────
# Public — safe for the browser.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only — bypasses RLS. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Database (Project Settings → Database → Connection string) ─────────────
# Use the "Transaction" pooler URL (port 6543) for the app. Drizzle Kit
# migrations can use the "Session" pooler (port 5432).
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-region.pooler.supabase.com:6543/postgres"

# ── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── AI providers (optional until the AI layer goes live) ────────────────────
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# ── Payments — Mollie (optional until billing goes live) ────────────────────
MOLLIE_API_KEY=""
